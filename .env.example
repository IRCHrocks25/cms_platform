# ---------------------------------------------------------------------------
# cms_platform — sample environment
# Copy to `.env` for local dev, or set these in your prod environment.
# ---------------------------------------------------------------------------

# Django secret key. The default in settings.py is a dev placeholder; for
# any non-dev environment this MUST be set to a random, private value.
# Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=dev-only-secret-change-me-in-production

# Debug mode. "1" enables Django DEBUG, "0" disables it.
# Production: set to 0.
DJANGO_DEBUG=1

# Base domain for tenant subdomain routing.
#   - Dev default: localhost (Chrome/Firefox auto-resolve *.localhost via RFC 6761)
#   - If your DNS doesn't honor *.localhost, use lvh.me  → http://acme.lvh.me:8000/
#   - Production: your real wildcard host, e.g. sites.youragency.com
#     (and point *.sites.youragency.com at this app via Caddy/nginx/Cloudflare)
TENANT_BASE_DOMAIN=localhost

# ---------------------------------------------------------------------------
# Custom client domains (direct-to-origin + Let's Encrypt).
# Clients point an A record at this origin IP; Traefik then issues a real
# Let's Encrypt cert per domain via HTTP-01. The dashboard's verify step checks
# the domain's A record resolves here. Prod default is the Hetzner origin IP.
# ---------------------------------------------------------------------------
CUSTOM_DOMAIN_TARGET_IP=5.78.149.237

# ---------------------------------------------------------------------------
# GHL (GoHighLevel) marketplace app integration.
# ---------------------------------------------------------------------------
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=
# Fernet key for encrypting GHL tokens at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
GHL_TOKEN_ENCRYPTION_KEY=
# Optional: explicit GHL app version id (defaults to the GHL_CLIENT_ID prefix).
GHL_APP_VERSION_ID=
